rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isPlayer(code) {
      return isAuth() &&
        exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.auth.uid));
    }

    function isHost(code) {
      return isAuth() &&
        get(/databases/$(database)/documents/rooms/$(code)).data.hostId == request.auth.uid;
    }

    match /rooms/{code} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.phase == "lobby";
      allow update: if isPlayer(code);
      allow delete: if isHost(code);

      match /players/{playerId} {
        allow read: if isAuth();
        allow create: if isAuth() && (playerId == request.auth.uid || isHost(code));
        allow update: if isAuth() && (playerId == request.auth.uid || isHost(code));
        allow delete: if isAuth() && (playerId == request.auth.uid || isHost(code));
      }

      match /secrets/{playerId} {
        // CRITICAL: Each player can ONLY read their own secret
        allow read: if isAuth() && playerId == request.auth.uid;
        allow create: if isHost(code);
        // Host can update (needed for atomic playAgain: delete+set in one batch
        // is evaluated by rules as update since the doc exists pre-batch).
        allow update: if isHost(code);
        allow delete: if isHost(code);
      }
    }
  }
}
